msgstr "No se reconoce la clave de administrador. Comprueba que sea la clave correcta y que no haya sido revocada."

#: includes/class-admin-hooks.php:93
msgid "This is a provisioning key, not an account admin key. Mint one with `./bin/sw account add-admin-key`."
msgstr "Esta es una clave de aprovisionamiento, no una clave de administrador de cuenta. Crea una con `./bin/sw account add-admin-key`."


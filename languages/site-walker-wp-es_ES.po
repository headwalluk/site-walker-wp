msgstr "Lista de países"

#: admin-templates/tabs/geo.php:66
msgid "ISO 3166-1 alpha-2 codes (two letters each), separated by commas, spaces, or newlines. Ignored when mode is \"Allow all\"."
msgstr "Códigos ISO 3166-1 alfa-2 (de dos letras cada uno), separados por comas, espacios o saltos de línea. Se ignoran cuando el modo es «Permitir todo»."


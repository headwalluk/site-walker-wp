#: includes/class-admin-hooks.php:39
msgid "Insufficient permissions."
msgstr "Brak odpowiednich uprawnień."

#: includes/class-admin-hooks.php:91
msgid "Something went wrong. Please try again."
msgstr "Wystąpił błąd. Spróbuj ponownie."

#: includes/class-admin-hooks.php:92
msgid "Admin key not recognised. Check that it's the right key and hasn't been revoked."
msgstr "Klucz administratora nie został rozpoznany. Sprawdź, czy jest to właściwy klucz i czy nie został unieważniony."

#: includes/class-admin-hooks.php:93
msgid "This is a provisioning key, not an account admin key. Mint one with `./bin/sw account add-admin-key`."
msgstr "To jest klucz do zarządzania zasobami, a nie klucz administratora konta. Utwórz go za pomocą polecenia `./bin/sw account add-admin-key`."

#: includes/class-admin-hooks.php:94
msgid "No chatbot found with this slug."
msgstr "Nie znaleziono chatbota o tym slugu."

#: includes/class-admin-hooks.php:95
msgid "Couldn't reach the API server. Check the URL is correct and the server is up."
msgstr "Nie udało się połączyć z serwerem API. Sprawdź, czy adres URL jest poprawny i czy serwer działa."

#: includes/class-admin-hooks.php:96
msgid "Admin key works, but no chatbots were found for the account. Create one with `./bin/sw chatbot create`."
msgstr "Klucz administratora działa, ale nie znaleziono żadnych chatbotów dla tego konta. Utwórz chatbota za pomocą polecenia `./bin/sw chatbot create`."

#. translators: %s: site origin like https://example.com
#: includes/class-admin-hooks.php:98
#, php-format
msgid "No chatbot in this account has %1$s on its origin allowlist. Add it upstream with: sw chatbot origins add <slug> %2$s"
msgstr "Żaden chatbot na tym koncie nie ma %1$s na liście dozwolonych źródeł. Dodaj go, wykonując następujące polecenie: sw chatbot origins add <slug> %2$s"

#: includes/class-admin-hooks.php:99
msgid "The saved chatbot no longer lists this site as an allowed origin. Re-save your admin key to find the right chatbot, or add this origin upstream."
msgstr "Zapisany chatbot nie uwzględnia już tej witryny jako dozwolonego źródła. Zapisz ponownie swój klucz administratora, aby znaleźć właściwego chatbota, lub dodaj to źródło na wyższym poziomie."

#: includes/class-admin-hooks.php:100
msgid "Connection OK."
msgstr "Połączenie nawiązane."

#: includes/class-admin-hooks.php:101
msgid "Saved. Connected to:"
msgstr "Zapisano. Połączono z:"

#: includes/class-admin-hooks.php:102
msgid "Saved."
msgstr "Zapisano."

#: includes/class-admin-hooks.php:103
msgid "Clear the saved admin key? You'll need to paste it again to manage the chatbot from here."
msgstr "Chcesz usunąć zapisany klucz administratora? Będziesz musiał go wkleić ponownie, aby móc zarządzać chatbotem z tego miejsca."

#: includes/class-admin-hooks.php:104

#: admin-templates/tabs/usage.php:66
msgid "Customer"
msgstr "Πελάτης"

#: admin-templates/tabs/usage.php:66
msgid "Counts toward the daily-cap budget."
msgstr "Υπολογίζεται στο ημερήσιο όριο του προϋπολογισμού."

#: admin-templates/tabs/usage.php:67
msgid "Admin mode"
msgstr "Λειτουργία διαχειριστή"

#: admin-templates/tabs/usage.php:67
msgid "Logged-in WP admin sessions; excluded from the daily-cap budget."
msgstr "Συνδέσεις διαχειριστή στο WP· εξαιρούνται από το ημερήσιο όριο."

#: admin-templates/tabs/usage.php:74
msgid "Cost (USD)"
msgstr "Κόστος (USD)"

#: admin-templates/tabs/usage.php:75
msgid "Tokens — input"
msgstr "Μάρκες — εισαγωγή"

#: admin-templates/tabs/usage.php:76
msgid "Tokens — output"
msgstr "Μάρκες — έξοδος"

#: admin-templates/tabs/usage.php:77

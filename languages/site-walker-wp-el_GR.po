msgstr "Διακριτικά — ανάγνωση από την προσωρινή μνήμη"

#: admin-templates/tabs/usage.php:90
msgid "Period"
msgstr "Περίοδος"

#: includes/class-admin-hooks.php:39
msgid "Insufficient permissions."
msgstr "Ανεπαρκή δικαιώματα."

#: includes/class-admin-hooks.php:91
msgid "Something went wrong. Please try again."
msgstr "Παρουσιάστηκε κάποιο σφάλμα. Παρακαλώ δοκιμάστε ξανά."

#: includes/class-admin-hooks.php:92
msgid "Admin key not recognised. Check that it's the right key and hasn't been revoked."
msgstr "Το κλειδί διαχειριστή δεν αναγνωρίζεται. Βεβαιωθείτε ότι είναι το σωστό κλειδί και ότι δεν έχει ανακληθεί."

#: includes/class-admin-hooks.php:93
msgid "This is a provisioning key, not an account admin key. Mint one with `./bin/sw account add-admin-key`."
msgstr "Αυτό είναι ένα κλειδί προμήθειας, όχι ένα κλειδί διαχειριστή λογαριασμού. Δημιουργήστε ένα με την εντολή `./bin/sw account add-admin-key`."

#: includes/class-admin-hooks.php:94
msgid "No chatbot found with this slug."
msgstr "Δεν βρέθηκε chatbot με αυτό το slug."

#: includes/class-admin-hooks.php:95
msgid "Couldn't reach the API server. Check the URL is correct and the server is up."
msgstr "Δεν ήταν δυνατή η σύνδεση με τον διακομιστή API. Ελέγξτε αν η διεύθυνση URL είναι σωστή και αν ο διακομιστής λειτουργεί."

#: includes/class-admin-hooks.php:96
msgid "Admin key works, but no chatbots were found for the account. Create one with `./bin/sw chatbot create`."
msgstr "Το κλειδί διαχειριστή λειτουργεί, αλλά δεν εντοπίστηκαν chatbots για τον λογαριασμό. Δημιουργήστε ένα με την εντολή `./bin/sw chatbot create`."

#. translators: %s: site origin like https://example.com
#: includes/class-admin-hooks.php:98
#, php-format
msgid "No chatbot in this account has %1$s on its origin allowlist. Add it upstream with: sw chatbot origins add <slug> %2$s"
msgstr "Κανένα chatbot σε αυτόν τον λογαριασμό δεν έχει το %1$s στη λίστα επιτρεπόμενων πηγών του. Προσθέστε το στην πηγή με την εντολή: sw chatbot origins add <slug> %2$s"

#: includes/class-admin-hooks.php:99
msgid "The saved chatbot no longer lists this site as an allowed origin. Re-save your admin key to find the right chatbot, or add this origin upstream."
msgstr "Το αποθηκευμένο chatbot δεν αναγνωρίζει πλέον αυτόν τον ιστότοπο ως επιτρεπόμενη πηγή. Αποθηκεύστε ξανά το κλειδί διαχειριστή για να βρείτε το σωστό chatbot ή προσθέστε αυτήν την πηγή στην αρχή της αλυσίδας."

#: includes/class-admin-hooks.php:100
msgid "Connection OK."
msgstr "Η σύνδεση είναι εντάξει."

#: includes/class-admin-hooks.php:101
msgid "Saved. Connected to:"
msgstr "Αποθηκεύτηκε. Συνδεδεμένος με:"

#: includes/class-admin-hooks.php:102
msgid "Saved."
msgstr "Αποθηκεύτηκε."

#: includes/class-admin-hooks.php:103
msgid "Clear the saved admin key? You'll need to paste it again to manage the chatbot from here."
msgstr "Θέλετε να διαγράψετε το αποθηκευμένο κλειδί διαχειριστή; Θα χρειαστεί να το επικολλήσετε ξανά για να διαχειριστείτε το chatbot από εδώ."

#: includes/class-admin-hooks.php:104
msgid "Not connected."
msgstr "Δεν υπάρχει σύνδεση."

#: includes/class-public-hooks.php:82
msgid "Open chat"
msgstr "Άνοιγμα συνομιλίας"

#: includes/class-public-hooks.php:112
msgid "Chat"
msgstr "Γάτα"

#: includes/class-public-hooks.php:116
msgid "Close chat"
msgstr "Κλείσιμο συνομιλίας"

#: includes/class-public-hooks.php:123
msgid "Send message"
msgstr "Αποστολή μηνύματος"

#: includes/class-public-hooks.php:133
msgid "Request an email back"
msgstr "Ζητήστε να σας απαντήσουμε μέσω email"

#: includes/class-public-hooks.php:146
msgid "Your email address"
msgstr "Η διεύθυνση ηλεκτρονικού ταχυδρομείου σας"

#: includes/class-public-hooks.php:147
msgid "Send email"
msgstr "Αποστολή email"

#: includes/class-public-hooks.php:151
msgid "← Back to chat"
msgstr "← Επιστροφή στη συνομιλία"

#: includes/class-settings.php:167

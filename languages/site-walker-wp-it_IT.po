msgstr "Impossibile connettersi al server API. Verifica che l'URL sia corretto e che il server sia attivo."

#: includes/class-admin-hooks.php:96
msgid "Admin key works, but no chatbots were found for the account. Create one with `./bin/sw chatbot create`."
msgstr "La chiave di amministratore funziona, ma non sono stati trovati chatbot per l'account. Creane uno con `./bin/sw chatbot create`."


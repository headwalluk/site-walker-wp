#: admin-templates/settings-page.php:24
msgid "Context"
msgstr "Contesto"

#: admin-templates/tabs/blocks.php:41
msgid "Context blocks are snippets of background knowledge the assistant gets with every conversation — store policies, shipping rules, tone reminders, anything it should always know. Add as many as you need."
msgstr "I blocchi di contesto sono frammenti di informazioni di base che l'assistente acquisisce ad ogni conversazione: politiche del negozio, regole di spedizione, indicazioni sul tono da adottare e tutto ciò che dovrebbe sempre sapere. Aggiungine quanti ne vuoi."

#: admin-templates/tabs/blocks.php:46
msgid "Add block"
msgstr "Aggiungi blocco"


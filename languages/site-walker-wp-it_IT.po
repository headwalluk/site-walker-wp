msgstr "API server"

#: admin-templates/tabs/connection.php:28
msgid "Base URL of the Site Walker API instance this WordPress site talks to. Changing the URL clears the saved admin key, since keys are scoped to a specific API instance."
msgstr "URL di base dell'istanza dell'API Site Walker con cui comunica questo sito WordPress. Modificando l'URL, la chiave di amministrazione salvata viene cancellata, poiché le chiavi sono associate a un'istanza specifica dell'API."

#: admin-templates/tabs/connection.php:33
msgid "API URL"
msgstr "URL dell'API"

#: admin-templates/tabs/connection.php:41
#: admin-templates/tabs/connection.php:54

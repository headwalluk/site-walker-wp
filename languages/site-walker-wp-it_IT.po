#: includes/class-admin-hooks.php:92
msgid "Admin key not recognised. Check that it's the right key and hasn't been revoked."
msgstr "Chiave di amministratore non riconosciuta. Verifica che sia quella corretta e che non sia stata revocata."

#: includes/class-admin-hooks.php:93
msgid "This is a provisioning key, not an account admin key. Mint one with `./bin/sw account add-admin-key`."
msgstr "Questa è una chiave di provisioning, non una chiave di amministratore dell'account. Creane una con il comando `./bin/sw account add-admin-key`."

